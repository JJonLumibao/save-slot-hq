generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  REGULAR
  PREMIUM
  ADMIN
}

model User {
  id           Int    @id @default(autoincrement())
  firstName    String
  lastName     String
  username     String @unique
  email        String @unique
  passwordHash String
  role         Role   @default(REGULAR)

  favorites    Game[] @relation("Favorites")
  reviews      Review[]
}

model Game {
  id           Int    @id @default(autoincrement())
  name         String
  description  String

  favoritedBy  User[] @relation("Favorites")
  reviews      Review[]
}

model Review {
  id        Int   @id @default(autoincrement())
  rating    Int
  comment   String

  userId    Int
  gameId    Int

  user      User @relation(fields: [userId], references: [id])
  game      Game @relation(fields: [gameId], references: [id])
}